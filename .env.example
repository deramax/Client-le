# ============================================================
#  ClienTara — configuration (copier vers .env)
#  NE JAMAIS committer le fichier .env réel.
# ============================================================

# ---- Django ----
DJANGO_SECRET_KEY=change-me-genere-une-longue-chaine-aleatoire-50-caracteres
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
TIME_ZONE=Indian/Antananarivo

# ---- Base de données ----
# Avec Docker : DB_HOST=db (PostgreSQL). En local sans Docker : laisser DB_HOST
# VIDE pour utiliser SQLite automatiquement (zéro configuration).
DB_NAME=clientara
DB_USER=clientara
DB_PASSWORD=clientara
DB_HOST=db
DB_PORT=5432

# ---- JWT ----
JWT_ACCESS_MIN=120
JWT_REFRESH_DAYS=7

# ---- CORS ----
CORS_ALLOW_ALL=true
# CORS_ALLOWED_ORIGINS=http://localhost:8080

# ---- Compte administrateur initial (créé par `seed_demo`) ----
DJANGO_ADMIN_LOGIN=admin
DJANGO_ADMIN_PASSWORD=Clientara2026!
SEED_DEMO=true

# ---- Source de données : demo | production ----
DATA_SOURCE=demo

# ---- 4D (mode production) — ⚠️ valeurs fournies par la DSI ----
FOURD_URL=
FOURD_USER=
FOURD_PASSWORD=
FOURD_TIMEOUT=10000
# Jeton optionnel pour protéger le portail /api/fourd
API_TOKEN=

# ---- LDAP — ⚠️ désactivé par défaut ; annuaire fourni par la DSI ----
# Pour tester en local : `docker compose --profile ldap up` puis LDAP_ENABLED=true
LDAP_ENABLED=false
LDAP_SERVER_URI=ldap://openldap:389
LDAP_BIND_DN=cn=admin,dc=clientara,dc=local
LDAP_BIND_PASSWORD=admin
LDAP_USER_BASE=ou=people,dc=clientara,dc=local
LDAP_USER_FILTER=(uid=%(user)s)
# LDAP_GROUP_BASE=ou=groups,dc=clientara,dc=local
# LDAP_ADMIN_GROUP=cn=admins,ou=groups,dc=clientara,dc=local
